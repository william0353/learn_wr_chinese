  },
  {
    "id": 30,
    "words": ["书", "本", "字", "文"],
    "note": "学习篇。本=木+一；字=宀+子。"
  },
  {
    "id": 31,
    "words": ["沙", "尘", "石", "岩"],
    "note": "自然逻辑篇。沙=水+少；尘=小+土；岩=山+石。"
  },
  {
    "id": 32,
    "words": ["休", "体", "位", "仙"],
    "note": "单人旁逻辑篇。休=人+木；体=人+本；位=人+立；仙=人+山。"
  },
  {
    "id": 33,
    "words": ["多", "太", "双", "朋"],
    "note": "叠字与加点。多=夕+夕；太=大+点；双=又+又；朋=月+月。"
  },
  {
    "id": 34,
    "words": ["吃", "叫", "说", "话"],
    "note": "嘴巴动作篇。话=讠+舌（舌头）。"
  },
  {
    "id": 35,
    "words": ["只", "古", "名", "可"],
    "note": "口字组合篇。只=口+八；古=十+口；名=夕+口；可=丁+口。"
  },
  {
